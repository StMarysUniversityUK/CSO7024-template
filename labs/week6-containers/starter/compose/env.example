# Environment variables for the Week 6 Compose lab (6.2).
#
# Copy this file to .env and set a value:  cp .env.example .env
# Docker Compose loads .env automatically. Your real .env is git-ignored, so the
# password is never committed; this .env.example is the tracked template.

# Password for the Postgres database. The compose file uses it in two places
# (the database's POSTGRES_PASSWORD and the app's DATABASE_URL), so a single
# value here keeps them in step.
DB_PASSWORD=change-me
